# Weaviate Configuration
# Copy this file to .env and update with your values

# Weaviate server host (default: localhost:8080)
WEAVIATE_HOST=localhost:8080

# Protocol scheme (default: http)
WEAVIATE_SCHEME=http

# Connection timeout in seconds (default: 1)
WEAVIATE_STARTUP_TIMEOUT=5

# API key for authentication (optional)
# Leave empty for local development without auth
WEAVIATE_API_KEY=your-api-key-here

# Default collection name for operations (default: DefaultCollection)
WEAVIATE_DEFAULT_COLLECTION=DefaultCollection